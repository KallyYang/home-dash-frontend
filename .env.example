# Backend API base URL.
#
# Two ways to configure:
#
# 1) Build-time (baked into the browser bundle):
#    Define NEXT_PUBLIC_API_BASE here. It will be inlined by `next build`.
#    Used as a fallback when the runtime /api/config endpoint is unreachable.
NEXT_PUBLIC_API_BASE=http://localhost:8080

# 2) Runtime (no rebuild needed, recommended for Cloudflare Workers):
#    Set API_BASE on the Worker (wrangler.jsonc `vars` or
#    Cloudflare Dashboard → Settings → Variables and Secrets).
#    The frontend fetches it via /api/config on first request.
# API_BASE=https://api.home-dash.yourdomain.com

# Optional: dashboard access password. When set, users must enter this
# password before accessing any page. Leave empty to disable auth.
# NOTE: this is a NEXT_PUBLIC_* variable, so the value will be embedded
# in the client bundle. It only provides casual protection (e.g. on a
# home network) and is NOT a substitute for proper server-side auth.
NEXT_PUBLIC_ACCESS_PASSWORD=
